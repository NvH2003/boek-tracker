# InstantDB – cloud backend
# Maak een app aan op https://instantdb.com en vul hier in:
VITE_INSTANT_APP_ID=jouw-app-id
INSTANT_ADMIN_TOKEN=jouw-admin-token
INSTANT_APP_ID=jouw-app-id

# Google Books – voor zoeken en genre-ophalen in de browser
VITE_GOOGLE_BOOKS_API_KEY=jouw-google-books-api-key

# Voor de Vercel API route /api/genres (server-side genre ophalen)
GOOGLE_BOOKS_API_KEY=jouw-google-books-api-key

# Alleen nodig bij het uitvoeren van het eenmalige migratiescript
VITE_SUPABASE_URL=https://...supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
