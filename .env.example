# Kopieer naar `.env` en vul in (`.env` wordt niet gecommit).

# Supabase
VITE_SUPABASE_URL=https://jouw-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=jouw-anon-of-publishable-key

# Google Books API (zoeken + automatische genres in de browser)
# Zie: Google Cloud Console → Books API inschakelen → API key aanmaken
VITE_GOOGLE_BOOKS_API_KEY=jouw-google-books-api-key
